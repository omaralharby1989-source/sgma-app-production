# SGMA APP — Environment Variable Template
# Copy this file to ".env" and fill in real values in a TRUSTED environment only.
# NEVER commit a real .env file. NEVER share these values publicly.
# All values below are PLACEHOLDERS — they are not real secrets.

# --- Required ---
# PostgreSQL connection string used by the API server and Drizzle.
DATABASE_URL=postgresql://USER:PASSWORD@HOST:5432/DATABASE_NAME

# Secret used to sign/verify JWT auth tokens.
# If JWT_SECRET is not set, the server falls back to SESSION_SECRET.
JWT_SECRET=replace-with-a-long-random-string
SESSION_SECRET=replace-with-a-long-random-string

# --- Optional / provided by the platform at runtime ---
# HTTP port the API/web server binds to (provided by the workflow on Replit).
PORT=5000
# Base path prefix the artifact is served under (provided by the workflow).
BASE_PATH=/
# Logging verbosity: debug | info | warn | error
LOG_LEVEL=info
# Node environment: development | production
NODE_ENV=development

# --- Native (Capacitor / Android) build only ---
# Absolute production API base URL the native app calls (e.g. https://api.example.org).
# Leave UNSET for normal web builds (web uses same-origin relative /api requests).
VITE_API_BASE_URL=
# Set to 1 only when running the Capacitor build (build:cap). Leave unset otherwise.
CAP_BUILD=
